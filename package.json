{
  "name": "manca",
  "version": "0.1.0",
  "description": "The missing trust layer for agent-to-agent commerce. A neutral clearinghouse where any agent buys AND sells, with machine-verifiable escrow, float, and a reputation graph — monetizable on day one.",
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "bin": {
    "manca": "dist/cli.mjs"
  },
  "files": [
    "dist/",
    "src/",
    "docs/",
    "manca.config.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SIML-Inc/Manca.git"
  },
  "homepage": "https://github.com/SIML-Inc/Manca",
  "scripts": {
    "init": "node --experimental-strip-types src/cli.ts init",
    "serve": "node --experimental-strip-types src/cli.ts serve",
    "mcp": "node --experimental-strip-types src/cli.ts mcp",
    "demo": "node --experimental-strip-types src/cli.ts demo",
    "x402:status": "node --experimental-strip-types src/cli.ts x402:status",
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.mjs --external:viem",
    "prepublishOnly": "npm run build",
    "test": "node --test --experimental-strip-types test/*.test.ts"
  },
  "optionalDependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "keywords": [
    "agent-commerce",
    "a2a",
    "clearinghouse",
    "escrow",
    "mcp",
    "ap2",
    "x402",
    "agentic-commerce",
    "settlement",
    "reputation"
  ],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {}
}
