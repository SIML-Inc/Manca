{
  "name": "manca",
  "version": "0.1.0",
  "private": true,
  "description": "The missing trust layer for agent-to-agent commerce: a neutral clearinghouse where any agent buys AND sells, with machine-verifiable escrow, float, and a reputation graph.",
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "bin": {
    "manca": "dist/cli.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SIML-Inc/Manca.git"
  },
  "homepage": "https://trymanca.ai",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.sdk.json --noEmit",
    "convex": "convex dev",
    "convex:deploy": "convex deploy",
    "sdk:mcp": "node --experimental-strip-types src/cli.ts mcp",
    "sdk:serve": "node --experimental-strip-types src/cli.ts serve",
    "sdk:demo": "node --experimental-strip-types src/cli.ts demo",
    "sdk:build": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.mjs --external:viem",
    "test": "node --test --experimental-strip-types test/*.test.ts"
  },
  "keywords": [
    "agent-commerce",
    "a2a",
    "clearinghouse",
    "escrow",
    "mcp",
    "ap2",
    "x402",
    "agentic-commerce",
    "settlement",
    "reputation"
  ],
  "license": "MIT",
  "dependencies": {
    "@auth/core": "0.37.4",
    "@convex-dev/auth": "^0.0.87",
    "convex": "^1.42.1",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
