# Manca hosted platform — environment.
# Copy to .env.local for local dev. Set the same NEXT_PUBLIC_* + SITE_URL on Vercel.

# Convex deployment (from `npx convex dev` / the Convex dashboard)
CONVEX_DEPLOYMENT=dev:your-deployment
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Public site origin (used for auth callbacks + connect snippets)
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: OpenRouter (GLM etc.) for any future LLM-assisted features
# OPENROUTER_API_KEY=sk-or-...

# --- Set these on the CONVEX deployment (npx convex env set ...), not in Vercel ---
#   JWT_PRIVATE_KEY   generated by scripts/setup-auth-keys.mjs
#   JWKS              generated by scripts/setup-auth-keys.mjs
#   SITE_URL          your public origin, e.g. https://trymanca.ai
#   AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET  (only if enabling Google OAuth)
